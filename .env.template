# ─── Azure AI Foundry (project endpoint) ─────────────────
# Foundry project endpoint – used for Agent Service + LLM calls via DefaultAzureCredential.
# Run `az login` first so the SDK can pick up your identity.
FOUNDRY_PROJECT_ENDPOINT=https://<your-resource>.services.ai.azure.com/api/projects/<your-project>
FOUNDRY_MODEL_DEPLOYMENT_NAME=gpt-4.1

# Per-agent model overrides (optional). Indexer & Analyzer default to gpt-4.1-mini for speed;
# Advisor defaults to FOUNDRY_MODEL_DEPLOYMENT_NAME (gpt-4.1) for report quality.
# FOUNDRY_INDEXER_MODEL=gpt-4.1-mini
# FOUNDRY_ANALYZER_MODEL=gpt-4.1-mini
# FOUNDRY_ADVISOR_MODEL=gpt-4.1

# ─── Azure AI Document Intelligence (OCR) ────────────
# Used for OCR on scanned PDFs and images. Uses DefaultAzureCredential.
# If omitted, falls back to FOUNDRY_PROJECT_ENDPOINT.
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://<your-doc-intel>.cognitiveservices.azure.com
# PDF OCR policy: off | auto | hybrid | force
# PDF_OCR_MODE=auto
# Trigger OCR in auto/hybrid when embedded PDF text is sparse.
# PDF_MIN_EMBEDDED_TEXT_CHARS=120
# PDF_LOW_TEXT_PAGE_CHARS=35
# PDF_LOW_TEXT_PAGE_RATIO=0.4
# In auto mode, OCR replaces embedded text only if significantly richer.
# PDF_OCR_MIN_GAIN_FACTOR=1.15

# ─── Azure AI Search ──────────────────────────────────
# Used for follow-up chat RAG on large documents (200+ pages).
# Chunks are indexed in `vigil-document-chunks` and extracted facts in `vigil-facts`.
# Prefer DefaultAzureCredential (RBAC). If RBAC is not available, you can set
# AZURE_SEARCH_API_KEY as a fallback for local demos or isolated environments.
AZURE_SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net
# AZURE_SEARCH_API_KEY=<optional-search-admin-or-query-key>
# AZURE_SEARCH_CHUNKS_INDEX=vigil-document-chunks

# ─── Context provider tuning ──────────────────────────
SEARCH_CONTEXT_TOP_K=3
SEARCH_SNIPPET_MAX_CHARS=3000
# AZURE_SEARCH_FACTS_INDEX=vigil-facts
# SEARCH_FACTS_TOP_K=15

# ─── Application ──────────────────────────────────────
# VIGIL_PORT=3000
# Comma-separated allowed CORS origins for production (leave empty to deny all cross-origin)
# VIGIL_ALLOWED_ORIGINS=https://your-app.azurewebsites.net
# Optional API protection for external demos or client environments.
# If set, callers must send X-Vigil-Api-Key or Authorization: Bearer <key>.
# VIGIL_API_KEY=<strong-random-shared-secret>
# Require upstream platform auth headers (for example Easy Auth or reverse proxy identity).
# VIGIL_REQUIRE_PLATFORM_AUTH=true
# Upload/session safeguards.
# VIGIL_MAX_FILE_MB=50
# VIGIL_MAX_REQUEST_MB=100
# VIGIL_MAX_FILES=20
# UPLOAD_SESSION_TTL_SECONDS=3600

# ─── Large document chunking ─────────────────────────
# Documents above this word count are processed in chunks for better quality.
# Defaults work well for 200+ page documents. Adjust only if needed.
# LARGE_DOC_THRESHOLD=15000
# CHUNK_SIZE=4000
# CHUNK_OVERLAP=200
# MAX_CONCURRENT_CHUNKS=5
# Retry attempts for malformed (non-JSON) indexer outputs.
# INDEXER_RETRY_ATTEMPTS=2
# Deterministic fallback extraction limits used when indexer output is malformed.
# INDEXER_FALLBACK_MAX_NUMBERS=200
# INDEXER_FALLBACK_QUOTE_MAX_CHARS=12000

# ─── Gap Analysis Rulesets (optional) ─────────────────
# Deterministic YAML rules that run between Indexer and Analyzer for
# compliance_check and document_pack workflows. Not loaded by default.
# Uncomment to enable. See rulesets/default.yaml for examples.
# GAP_ANALYSIS_RULESET=rulesets/default.yaml
